NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Só usada no servidor — Route Handlers do agente local de impressão e dos
# webhooks de integração (ver src/lib/supabase/service-role.ts). NUNCA
# expor com o prefixo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app (QR do cardápio digital / redirects OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3010

# Chave simétrica (32 bytes, base64) usada para cifrar credenciais de
# integrações antes de gravar em integracoes_canais.credenciais_criptografadas
# (ver src/features/integracoes/crypto.ts). Gerar com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTEGRACOES_SECRET_KEY=

# Modo das integrações: homolog (default) | live | disabled
INTEGRACOES_MODE=homolog

# Assinatura HMAC compartilhada (fallback) para webhooks
INTEGRACOES_WEBHOOK_SECRET=

# Em live, permite gravar webhooks sem assinatura válida.
# Em homolog, unsigned já é aceito por padrão (defina false para forçar assinatura).
# INTEGRACOES_WEBHOOKS_ALLOW_UNSIGNED=true

# --- iFood (Prioridade 1) ---
IFOOD_API_BASE_URL=https://merchant-api.ifood.com.br
IFOOD_WEBHOOK_SECRET=

# --- WhatsApp Cloud API / Evolution (Prioridade 2) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- PIX (Prioridade 3) ---
ASAAS_API_BASE_URL=https://sandbox.asaas.com/api/v3
